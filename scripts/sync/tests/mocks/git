#!/usr/bin/env bash
# git stub for fetch-repo.sh tests
#
# Intercepts baseline-related git commands and returns canned values.
# All other git commands are forwarded to the real git binary.
#
# Environment controls:
#   MOCK_GIT_LS_REMOTE        stdout for ls-remote (default: empty = no tag)
#   MOCK_GIT_CAT_FILE_OUTPUT  message body for cat-file tag (default: empty)
#   MOCK_GIT_LS_FILES_OUTPUT  stdout for ls-files (default: unset = real git)
#
# Usage: prepend scripts/sync/tests/mocks/ to PATH before running tests.

REAL_GIT="$(which -a git | grep -v "$0" | head -1 || echo /usr/bin/git)"

case "$1" in
  "ls-remote")
    echo "${MOCK_GIT_LS_REMOTE:-}"
    exit 0
    ;;
  "fetch")
    # Silently succeed — the tag is not actually fetched; cat-file uses mock output
    exit 0
    ;;
  "cat-file")
    if [[ "${2:-}" == "tag" ]]; then
      # Emit a minimal annotated tag object structure.
      # read_baseline_commit() parses the first non-empty line after the blank separator.
      printf 'object 0000000000000000000000000000000000000000\ntype commit\ntag ref-update/test\ntagger Test User <test@example.com> 1234567890 +0000\n\n%s\n' \
        "${MOCK_GIT_CAT_FILE_OUTPUT:-}"
    fi
    exit 0
    ;;
  "ls-files")
    if [[ -n "${MOCK_GIT_LS_FILES_OUTPUT+set}" ]]; then
      printf '%s\n' "${MOCK_GIT_LS_FILES_OUTPUT}"
      exit 0
    fi
    exec "$REAL_GIT" "$@"
    ;;
  *)
    exec "$REAL_GIT" "$@"
    ;;
esac
